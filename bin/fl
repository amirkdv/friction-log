#!/usr/bin/env bash
# fl — friction log entrypoint. Thin shim that delegates to `python -m fl`.
set -e

# Resolve repo root from this script's location (follow symlinks).
_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
  _dir="$(cd -P "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
FL_REPO="$(cd -P "$(dirname "$_self")/.." && pwd)"

if command -v uv >/dev/null 2>&1; then
  exec uv run --project "$FL_REPO" --quiet python -m fl "$@"
else
  PYTHONPATH="$FL_REPO/src" exec python3 -m fl "$@"
fi
